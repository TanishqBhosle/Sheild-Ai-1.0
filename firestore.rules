rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Get user data safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ["tanishqbhosale2006@gmail.com", "tanishqadmin@gmail.com", "anupamsingh10@gmail.com", "sachin49@gmail.com"] ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          getUserData().role == 'admin'));
    }

    function isModerator() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          getUserData().role == 'moderator'));
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'moderator', 'admin'] &&
             (!('fullName' in data) || data.fullName == null || data.fullName is string) &&
             (!('createdAt' in data) || data.createdAt == null || data.createdAt is string);
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['userId', 'content', 'status']) &&
             data.userId == request.auth.uid &&
             isValidString(data.content, 1, 5000) &&
             data.status in ['processing', 'approved', 'flagged', 'rejected'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || 
                     request.resource.data.role == 'moderator' ||
                     (request.resource.data.role == 'admin' && request.auth.token.email in ["tanishqbhosale2006@gmail.com", "tanishqadmin@gmail.com", "anupamsingh10@gmail.com", "sachin49@gmail.com"]));
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
    }

    match /content_submissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isModerator());
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    match /moderation_results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isModerator());
      allow write: if false; // Only written by backend
    }

    match /review_queue/{queueId} {
      allow read, write: if isModerator();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only written by backend
    }

    match /tenant_policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /moderation_reports/{reportId} {
      allow read, write: if isAdmin();
    }
  }
}
