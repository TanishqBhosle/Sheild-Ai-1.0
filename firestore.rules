rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()       { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function role()         { return request.auth.token.get('role', 'user'); }
    function isAdmin()      { return isAuth() && role() == 'admin'; }
    function isMod()        { return isAuth() && role() in ['moderator','admin']; }
    function isOwner(id)    { return isAuth() && uid() == id; }
    function hasField(f)    { return f in request.resource.data; }
    function notChanging(f) {
      return !(f in request.resource.data.diff(resource.data).affectedKeys());
    }

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId)
                    && notChanging('role')
                    && notChanging('uid')
                    && notChanging('createdAt')
                    && notChanging('casesReviewed');
      allow create, delete: if false;
    }

    match /content/{contentId} {
      allow create: if isAuth()
                    && request.resource.data.submittedBy == uid()
                    && request.resource.data.type in ['text','image','audio','video']
                    && request.resource.data.isDeleted == false
                    && hasField('submittedAt')
                    && hasField('status')
                    && request.resource.data.status == 'analyzing';

      allow read:   if isMod() || (isAuth() && isOwner(resource.data.submittedBy));

      allow update: if isMod()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['status','isDeleted','deletedAt','deletedBy']);

      allow delete: if false;
    }

    match /moderation_results/{resultId} {
      allow read: if isMod()
               || (isAuth()
                   && exists(/databases/$(database)/documents/content/$(resource.data.contentId))
                   && get(/databases/$(database)/documents/content/$(resource.data.contentId))
                        .data.submittedBy == uid());

      allow create: if false;

      allow update: if isMod()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['finalDecision','reviewedBy','reviewedAt',
                                   'notes','isOverride']);

      allow delete: if false;
    }

    match /appeals/{appealId} {
      allow create: if isAuth()
                    && request.resource.data.userId == uid()
                    && request.resource.data.status == 'pending'
                    && hasField('contentId')
                    && hasField('reason')
                    && hasField('submittedAt');

      allow read:   if isMod() || (isAuth() && isOwner(resource.data.userId));

      allow update: if isMod()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['status','resolution','responseMessage',
                                   'reviewedBy','resolvedAt']);

      allow delete: if false;
    }

    match /policies/{policyId} {
      allow read:           if isMod();
      allow create, update: if isAdmin()
                            && request.resource.data.updatedBy == uid();
      allow delete:         if false;
    }

    match /moderation_rules/{ruleId} {
      allow read:   if isMod();
      allow create: if isAdmin()
                    && request.resource.data.createdBy == uid();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['isActive','name','conditions',
                                   'action','priority','updatedAt']);
      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow read:                if isAdmin();
      allow create, update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if isMod() && request.resource.data.moderatorId == uid();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    match /cache/{cacheId} {
      allow read, write: if false;
    }

    match /_rateLimit/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
