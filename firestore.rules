rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }
    function userOrgId() { return request.auth.token.orgId; }
    function userRole() { return request.auth.token.role; }
    function isAdmin() { return userRole() == 'admin'; }
    function isModerator() { return userRole() == 'moderator'; }
    function isUser() { return userRole() == 'user'; }
    function sameOrg(orgId) { return isAuthenticated() && userOrgId() == orgId; }

    match /organizations/{orgId} {
      allow read: if sameOrg(orgId) && (isAdmin() || isModerator() || isUser());
      allow update: if sameOrg(orgId) && isAdmin();
      allow delete: if false;

      match /members/{userId} { allow read: if sameOrg(orgId) && isAdmin(); allow write: if sameOrg(orgId) && isAdmin(); }
      match /content/{contentId} { allow read: if sameOrg(orgId); allow write: if false; }
      match /moderation_results/{id} { allow read: if sameOrg(orgId) && (isAdmin() || isModerator() || isUser()); allow write: if false; }
      match /audit_logs/{logId} { allow read: if sameOrg(orgId) && isAdmin(); allow write, delete: if false; }
      match /usage_logs/{period} { allow read: if sameOrg(orgId) && isAdmin(); allow write: if false; }
      match /policies/{policyId} { allow read: if sameOrg(orgId) && isAdmin(); allow write: if sameOrg(orgId) && isAdmin(); }
      match /feedback_signals/{signalId} { allow read: if sameOrg(orgId) && isAdmin(); allow write: if false; }
    }

    match /api_keys/{keyHash} { allow read, write: if false; }
    match /platform/{docId} { allow read, write: if false; }
  }
}
