rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──── Helpers ────
    function isAuthenticated() { return request.auth != null; }
    function userRole() { return isAuthenticated() && 'role' in request.auth.token ? request.auth.token.role : 'user'; }
    function isPlatformAdmin() { return userRole() == 'platform_admin'; }
    function isModerator() { return userRole() in ['moderator', 'platform_admin']; }

    // ──── Users ────
    match /users/{userId} {
      allow read: if isAuthenticated() && (userId == request.auth.uid || isPlatformAdmin());
      allow write: if isPlatformAdmin();
    }

    // ──── Content & Results (Flat) ────
    match /moderation_results/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    match /content/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    // ──── Audit Logs & Metrics ────
    match /audit_logs/{logId} {
      allow read: if isModerator();
      allow write: if false;
    }

    match /usage_metrics/{metricId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ──── Policies (Flat) ────
    match /policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }
    
    // ──── Global Stats ────
    match /platform/{docId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }
  }
}
