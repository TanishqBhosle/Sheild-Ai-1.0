# ────────────────────────────────────────────────────────────────────────────────
# Aegis AI Backend — Required Environment Variables
# Copy this to .env for local development, and set these in Render dashboard
# for production. NEVER commit .env files with real values to Git.
# ────────────────────────────────────────────────────────────────────────────────

# ─── Google Gemini AI ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
# Go to Firebase Console → Project Settings → Service Accounts → Generate New Key
# Copy the entire JSON file content and paste it as a single line JSON string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Firebase Project ID (from Firebase console)
GCLOUD_PROJECT=your-firebase-project-id

# ─── JWT Authentication ────────────────────────────────────────────────────────
# CRITICAL: Use a strong random secret in production (32+ characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_strong_random_jwt_secret_here

# ─── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5002

# ─── CORS (Optional) ──────────────────────────────────────────────────────────
# Add your Vercel frontend URL here to allow it (in addition to the defaults)
ALLOWED_ORIGIN=https://your-app.vercel.app

# ─── Firebase Emulators (Development Only — DO NOT SET IN PRODUCTION) ──────────
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
